//Custom CSS

/* =========================
   CUSTOM RIGHT DRAWER MENU
   AUTO-PULLS SQUARESPACE NAV
========================= */

@media screen and (min-width: 768px) {

  /* Hide normal desktop navigation visually */
  .header-display-desktop .header-nav,
  .header-display-desktop .header-actions {
    display: none !important;
  }

  /* Keep logo area tidy */
  .header-display-desktop .header-title-nav-wrapper {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
  }

  /* =========================
     HAMBURGER TOGGLE
  ========================= */
  .ij-menu-toggle {
    position: fixed;
    top: 28px;
    right: 28px;
    width: 58px;
    height: 58px;
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    outline: none !important;
    border-radius: 0 !important;
    background: transparent !important;
    background-image: none !important;
    box-shadow: none !important;
    filter: none !important;
    text-shadow: none !important;
    appearance: none !important;
    -webkit-appearance: none !important;
    -moz-appearance: none !important;
    -webkit-tap-highlight-color: transparent;
    cursor: pointer;
    z-index: 10002;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
  }

  .ij-menu-toggle:hover,
  .ij-menu-toggle:focus,
  .ij-menu-toggle:focus-visible,
  .ij-menu-toggle:active {
    border: none !important;
    outline: none !important;
    background: transparent !important;
    background-image: none !important;
    box-shadow: none !important;
  }

  .ij-menu-toggle::before,
  .ij-menu-toggle::after {
    content: none !important;
    display: none !important;
  }

  .ij-menu-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    margin: 0 auto;
    background: #ffffff;
    transition: all 0.3s ease;
  }

  body.ij-menu-open .ij-menu-toggle {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
    transform: scale(0.92);
    transition: opacity 0.25s ease, visibility 0.25s ease, transform 0.25s ease;
  }

  /* =========================
     OVERLAY
  ========================= */
  .ij-menu-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.28);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.35s ease, visibility 0.35s ease;
    z-index: 10000;
  }

  /* =========================
     DRAWER
  ========================= */
  .ij-menu-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: min(34vw, 560px);
    min-width: 380px;
    max-width: 100vw;
    height: 100vh;
    background: #061123;
    transform: translateX(100%);
    transition: transform 0.45s cubic-bezier(.22,1,.36,1);
    z-index: 10001;
    overflow-y: auto;
    box-shadow: -24px 0 60px rgba(0,0,0,0.22);
  }

  .ij-menu-inner {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 235px 48px 72px;
    box-sizing: border-box;
  }

  body.ij-menu-open .ij-menu-drawer {
    transform: translateX(0);
  }

  body.ij-menu-open .ij-menu-overlay {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  body.ij-menu-open {
    overflow: hidden;
  }

  /* =========================
     CLOSE BUTTON
  ========================= */
  .ij-menu-close {
    position: absolute;
    top: 30px;
    right: 28px;
    width: 46px;
    height: 46px;
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    outline: none !important;
    border-radius: 0 !important;
    background: transparent !important;
    background-image: none !important;
    box-shadow: none !important;
    appearance: none !important;
    -webkit-appearance: none !important;
    cursor: pointer;
    display: block;
  }

  .ij-menu-close::before,
  .ij-menu-close::after {
    content: none !important;
    display: none !important;
  }

  .ij-menu-close span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 1.5px;
    background: #ffffff;
    display: block;
    transform-origin: center;
  }

  .ij-menu-close span:first-child {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .ij-menu-close span:last-child {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  /* =========================
     AUTO-PULLED NAV
  ========================= */
  .ij-menu-nav {
    width: 100%;
    max-width: 340px;
  }

  .ij-menu-nav .header-nav-list {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .ij-menu-nav .header-nav-item {
    width: 100% !important;
    list-style: none !important;
    margin: 0 0 10px !important;
    padding: 0 !important;
  }

  .ij-menu-nav .header-nav-item > a,
  .ij-menu-nav .header-nav-item > button,
  .ij-menu-nav .header-nav-item > summary,
  .ij-menu-nav .header-nav-item > .header-nav-folder-title,
  .ij-menu-nav .header-nav-item > .header-nav-item-link {
    display: block !important;
    width: 100% !important;
    color: #F5F8FF !important;
    text-decoration: none !important;
    font-size: 16px !important;
    line-height: 1.18 !important;
    letter-spacing: -0.02em !important;
    font-weight: 500 !important;
    padding: 6px 0 !important;
    margin: 0 !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    text-align: left !important;
    transition: color 0.25s ease, transform 0.25s ease !important;
  }

  .ij-menu-nav .header-nav-item > a:hover,
  .ij-menu-nav .header-nav-item > button:hover,
  .ij-menu-nav .header-nav-item > summary:hover,
  .ij-menu-nav .header-nav-item > .header-nav-folder-title:hover,
  .ij-menu-nav .header-nav-item > .header-nav-item-link:hover {
    color: #52F5A0 !important;
    transform: translateX(4px) !important;
  }

  /* Folder parents */
  .ij-menu-nav .header-nav-item--folder > a,
  .ij-menu-nav .header-nav-item--folder > button,
  .ij-menu-nav .header-nav-item--folder > summary,
  .ij-menu-nav .header-nav-item--folder > .header-nav-folder-title,
  .ij-menu-nav .header-nav-item--folder > .header-nav-item-link {
    position: relative !important;
    padding-right: 24px !important;
  }

  .ij-menu-nav .header-nav-item--folder > a::after,
  .ij-menu-nav .header-nav-item--folder > button::after,
  .ij-menu-nav .header-nav-item--folder > summary::after,
  .ij-menu-nav .header-nav-item--folder > .header-nav-folder-title::after,
  .ij-menu-nav .header-nav-item--folder > .header-nav-item-link::after {
    content: "›";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 17px;
    color: rgba(255,255,255,0.68);
  }

  /* Show child items underneath */
  .ij-menu-nav .header-nav-folder-content,
  .ij-menu-nav .header-nav-item ul {
    display: block !important;
    width: 100% !important;
    margin: 6px 0 0 !important;
    padding: 0 0 0 14px !important;
    border-left: 1px solid rgba(255,255,255,0.10) !important;
    box-sizing: border-box;
  }

  .ij-menu-nav .header-nav-folder-content .header-nav-item,
  .ij-menu-nav .header-nav-item ul .header-nav-item,
  .ij-menu-nav .header-nav-folder-content li,
  .ij-menu-nav .header-nav-item ul li {
    width: 100% !important;
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .ij-menu-nav .header-nav-folder-content a,
  .ij-menu-nav .header-nav-folder-content button,
  .ij-menu-nav .header-nav-folder-content summary,
  .ij-menu-nav .header-nav-item ul a,
  .ij-menu-nav .header-nav-item ul button,
  .ij-menu-nav .header-nav-item ul summary {
    display: block !important;
    width: 100% !important;
    color: rgba(245,248,255,0.72) !important;
    text-decoration: none !important;
    font-size: 13px !important;
    font-weight: 400 !important;
    line-height: 1.25 !important;
    letter-spacing: -0.01em !important;
    padding: 5px 0 !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    text-align: left !important;
    transition: color 0.25s ease, transform 0.25s ease !important;
  }

  .ij-menu-nav .header-nav-folder-content a:hover,
  .ij-menu-nav .header-nav-folder-content button:hover,
  .ij-menu-nav .header-nav-folder-content summary:hover,
  .ij-menu-nav .header-nav-item ul a:hover,
  .ij-menu-nav .header-nav-item ul button:hover,
  .ij-menu-nav .header-nav-item ul summary:hover {
    color: #52F5A0 !important;
    transform: translateX(4px) !important;
  }

  /* =========================
     FOOTER AREA
  ========================= */
  .ij-menu-footer {
    margin-top: 34px;
    width: 100%;
    max-width: 340px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
  }

  .ij-menu-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }

  .ij-menu-socials a {
    color: rgba(255,255,255,0.84);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.2;
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .ij-menu-socials a:hover {
    color: #52F5A0;
    transform: translateX(2px);
  }

  .ij-menu-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 278px;
    max-width: 100%;
    height: 68px;
    padding: 0 28px;
    background: #52F5A0;
    color: #061123;
    text-decoration: none;
    font-size: 18px;
    font-weight: 600;
    border-radius: 6px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .ij-menu-cta:hover {
    transform: translateY(-1px);
    opacity: 0.96;
    color: #061123;
  }
}

/* Mobile keeps native Squarespace mobile menu */
@media screen and (max-width: 767px) {
  .ij-drawer-system {
    display: none !important;
  }
}

//Footer Code Injection

<div class="ij-drawer-system">
  <button class="ij-menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="ij-drawer">
    <span></span>
    <span></span>
  </button>

  <div class="ij-menu-overlay"></div>

  <aside class="ij-menu-drawer" id="ij-drawer" aria-hidden="true">
    <button class="ij-menu-close" aria-label="Close menu">
      <span></span>
      <span></span>
    </button>

    <div class="ij-menu-inner">
      <nav class="ij-menu-nav"></nav>

      <div class="ij-menu-footer">
        <div class="ij-menu-socials">
          <a href="https://youtube.com/@YOURUSERNAME" target="_blank" rel="noopener">YouTube</a>
          <a href="https://instagram.com/YOURUSERNAME" target="_blank" rel="noopener">Instagram</a>
          <a href="https://linkedin.com/in/YOURUSERNAME" target="_blank" rel="noopener">LinkedIn</a>
        </div>

        <a href="/contact" class="ij-menu-cta">Call Us</a>
      </div>
    </div>
  </aside>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const toggle = document.querySelector('.ij-menu-toggle');
  const closeBtn = document.querySelector('.ij-menu-close');
  const drawer = document.querySelector('.ij-menu-drawer');
  const overlay = document.querySelector('.ij-menu-overlay');
  const body = document.body;
  const targetNav = document.querySelector('.ij-menu-nav');

  if (!toggle || !drawer || !overlay || !targetNav) return;

  function buildMenuFromSquarespaceNav() {
    const sourceNav =
      document.querySelector('.header-display-desktop .header-nav .header-nav-list') ||
      document.querySelector('.header-display-desktop .header-nav-list') ||
      document.querySelector('.header-nav .header-nav-list') ||
      document.querySelector('.header-nav-list');

    if (!sourceNav) return;

    const clone = sourceNav.cloneNode(true);
    targetNav.innerHTML = '';
    targetNav.appendChild(clone);
  }

  function openMenu() {
    buildMenuFromSquarespaceNav();
    body.classList.add('ij-menu-open');
    toggle.setAttribute('aria-expanded', 'true');
    drawer.setAttribute('aria-hidden', 'false');
  }

  function closeMenu() {
    body.classList.remove('ij-menu-open');
    toggle.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
  }

  toggle.addEventListener('click', function () {
    if (body.classList.contains('ij-menu-open')) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  if (closeBtn) {
    closeBtn.addEventListener('click', closeMenu);
  }

  overlay.addEventListener('click', closeMenu);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      closeMenu();
    }
  });

  document.addEventListener('click', function (e) {
    const link = e.target.closest('.ij-menu-nav a');
    if (link) {
      closeMenu();
    }
  });

  buildMenuFromSquarespaceNav();
});
</script>
